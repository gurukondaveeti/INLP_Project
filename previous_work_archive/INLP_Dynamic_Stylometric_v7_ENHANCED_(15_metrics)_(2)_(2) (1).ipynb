        "# ============================================================\n",
        "# CELL: AUTOMATED ABLATION STUDY (With Feature Importance)\n",
        "# ============================================================\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "from sklearn.linear_model import LogisticRegression\n",
        "from sklearn.preprocessing import PolynomialFeatures\n",
        "from sklearn.metrics import accuracy_score, precision_recall_fscore_support, roc_auc_score\n",
        "from IPython.display import display\n",
        "import warnings\n",
        "\n",
        "warnings.filterwarnings('ignore') # Suppress convergence warnings\n",
        "\n",
        "def run_comprehensive_ablation(train_dataframe, test_dataframe):\n",
        "    print(\"🚀 Starting Comprehensive Ablation Study...\")\n",
        "    print(\"Testing combinations using your L2 model + Tracking Top Features.\\n\")\n",
        "\n",
        "    # 1. Exhaustive grid of bin ranges\n",
        "    ranges_to_test = [\n",
        "        (0, 100), (101, 200), (201, 300), (301, 400), (401, 500),\n",
        "        (501, 600), (601, 700), (701, 800), (801, 900), (901, 1000),\n",
        "        (1001, 99999), # Above 1000\n",
        "        (0, 200), (201, 400), (401, 600), (601, 800), (801, 1000),\n",
        "        (0, 300), (301, 600), (601, 1000),\n",
        "        (0, 500), (501, 1000),\n",
        "        (0, 99999)\n",
        "    ]\n",
        "\n",
        "    sample_sizes_to_test = [250, 500, 1000, 1500]\n",
        "\n",
        "    # 2. Pre-calculate word counts\n",
        "    train_df = train_dataframe.copy()\n",
        "    test_df = test_dataframe.copy()\n",
        "    train_df['_word_count'] = train_df['text'].apply(lambda t: len(str(t).split()))\n",
        "    test_df['_word_count']  = test_df['text'].apply(lambda t: len(str(t).split()))\n",
        "\n",
        "    results = []\n",
        "\n",
        "    for min_w, max_w in ranges_to_test:\n",
        "        pool_train = train_df[(train_df['_word_count'] >= min_w) & (train_df['_word_count'] <= max_w)]\n",
        "        pool_test  = test_df[(test_df['_word_count'] >= min_w) & (test_df['_word_count'] <= max_w)]\n",
        "\n",
        "        available_train_h = len(pool_train[pool_train['label'] == 0])\n",
        "        available_train_a = len(pool_train[pool_train['label'] == 1])\n",
        "        max_train_possible = min(available_train_h, available_train_a)\n",
        "\n",
        "        for target_samples in sample_sizes_to_test:\n",
        "            actual_samples = min(target_samples, max_train_possible)\n",
        "\n",
        "            idx = sample_sizes_to_test.index(target_samples)\n",
        "            if idx > 0 and actual_samples == min(sample_sizes_to_test[idx-1], max_train_possible):\n",
        "                continue\n",
        "\n",
        "            if actual_samples < 50:\n",
        "                continue\n",
        "\n",
        "            bin_name = f\"{min_w}-{max_w}\" if max_w != 99999 else (f\"{min_w}+\" if min_w > 0 else \"Global (All)\")\n",
        "            print(f\"🔄 Training: Range [{bin_name:<10}] | Samples/Class: {actual_samples}...\")\n",
        "\n",
        "            # --- TRAIN ---\n",
        "            h_train = pool_train[pool_train['label'] == 0].sample(n=actual_samples, random_state=42)\n",
        "            a_train = pool_train[pool_train['label'] == 1].sample(n=actual_samples, random_state=42)\n",
        "            cur_train = pd.concat([h_train, a_train]).sample(frac=1, random_state=42)\n",
        "\n",
        "            X_train_raw = cur_train['text'].apply(extract_stylometric_features).apply(pd.Series)[METRICS].fillna(0)\n",
        "            poly = PolynomialFeatures(degree=2, interaction_only=True, include_bias=False)\n",
        "            X_train_poly = poly.fit_transform(X_train_raw)\n",
        "            y_train = cur_train['label']\n",
        "\n",
        "            log_reg = LogisticRegression(max_iter=2000, class_weight={0: 1.25, 1: 1.0}, C=0.5, random_state=42)\n",
        "            log_reg.fit(X_train_poly, y_train)\n",
        "\n",
        "            # --- EXTRACT FEATURE IMPORTANCE ---\n",
        "            # Get the generated feature names (e.g. 'entropy burstiness')\n",
        "            feature_names = poly.get_feature_names_out(METRICS)\n",
        "            # Get absolute values of coefficients to find the strongest predictors\n",
        "            importance = np.abs(log_reg.coef_[0])\n",
        "            # Get indices of the top 3 highest weights\n",
        "            top_3_idx = np.argsort(importance)[::-1][:5]\n",
        "            # Format them as a readable string\n",
        "            top_features_str = \", \".join([f\"{feature_names[i]}\" for i in top_3_idx])\n",
        "\n",
        "            # --- TEST ---\n",
        "            available_test_h = len(pool_test[pool_test['label'] == 0])\n",
        "            available_test_a = len(pool_test[pool_test['label'] == 1])\n",
        "            test_samples = min(available_test_h, available_test_a, 1000)\n",
        "\n",
        "            if test_samples < 25:\n",
        "                continue\n",
        "\n",
        "            h_test = pool_test[pool_test['label'] == 0].sample(n=test_samples, random_state=42)\n",
        "            a_test = pool_test[pool_test['label'] == 1].sample(n=test_samples, random_state=42)\n",
        "            cur_test = pd.concat([h_test, a_test]).sample(frac=1, random_state=42)\n",
        "\n",
        "            X_test_raw = cur_test['text'].apply(extract_stylometric_features).apply(pd.Series)[METRICS].fillna(0)\n",
        "            X_test_poly = poly.transform(X_test_raw)\n",
        "            y_test = cur_test['label']\n",
        "\n",
        "            y_pred = log_reg.predict(X_test_poly)\n",
        "            y_prob = log_reg.predict_proba(X_test_poly)[:, 1]\n",
        "\n",
        "            # --- EVALUATE ---\n",
        "            acc = accuracy_score(y_test, y_pred)\n",
        "            prec, rec, f1, _ = precision_recall_fscore_support(y_test, y_pred, average='macro', zero_division=0)\n",
        "            try:\n",
        "                auc = roc_auc_score(y_test, y_prob)\n",
        "            except:\n",
        "                auc = float('nan')\n",
        "\n",
        "            results.append({\n",
        "                'Word Range': bin_name,\n",
        "                'Train Samples/Class': actual_samples,\n",
        "                'Test Samples/Class': test_samples,\n",
        "                'Accuracy': round(acc, 4),\n",
        "                'Macro F1': round(f1, 4),\n",
        "                'ROC-AUC': round(auc, 4),\n",
        "                'Top 3 Predictive Features': top_features_str  # <--- NEW COLUMN ADDED HERE\n",
        "            })\n",
        "\n",
        "    # 3. Format DataFrame and display\n",
        "    results_df = pd.DataFrame(results)\n",
        "    results_df = results_df.sort_values(by=['Macro F1', 'Accuracy'], ascending=[False, False]).reset_index(drop=True)\n",
        "\n",
        "    # Adjust pandas display settings so the feature column doesn't get cut off\n",
        "    pd.set_option('display.max_colwidth', None)\n",
        "\n",
        "    print(\"\\n\" + \"=\" * 120)\n",
        "    print(\"                 TOP CONFIGURATIONS RANKED BY F1-SCORE\")\n",
        "    print(\"=\" * 120)\n",
        "    display(results_df)\n",
        "\n",
        "    results_df.to_csv('baseline_ablation_results.csv', index=False)\n",
        "    print(\"\\n✅ Results saved to 'baseline_ablation_results.csv'\")\n",
        "    return results_df\n",
        "\n",
        "# Run the study\n",
        "ablation_results = run_comprehensive_ablation(train_df, test_df)"
      ],
